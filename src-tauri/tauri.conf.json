{
  "$schema": "https://raw.githubusercontent.com/nicholasio/v2-schema/main/tauri-conf-v2.schema.json",
  "productName": "SRT Repair Tool",
  "version": "0.1.0",
  "identifier": "com.srtrepair.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SRT Repair Tool",
        "width": 800,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {}
    }
  }
}
